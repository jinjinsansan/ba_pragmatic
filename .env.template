# =============================================================================
# LAPLACE Client Configuration
# =============================================================================
#
# This file is loaded by the Engine on startup. All values below are
# pre-configured for your account. You should NOT need to edit anything
# unless instructed by the administrator.
#
# IMPORTANT: Do NOT share this file with anyone. It contains your personal
# API key that grants access to the LAPLACE decision engine.
# =============================================================================

# --- Stake.com Credentials ---
# Leave these EMPTY. You will log in manually via the browser window
# that opens when you press START. After the first successful login,
# cookies are saved and subsequent launches will auto-login.
STAKE_USERNAME=
STAKE_PASSWORD=

# --- LAPLACE Decision Engine (VPS) ---
LAPLACE_USE_REMOTE=1
LAPLACE_API_URL=http://127.0.0.1:8000
LAPLACE_API_KEY=__API_KEY__
LAPLACE_USER=__USERNAME__

# --- SSH Tunnel to VPS ---
LAPLACE_SSH_HOST=laplace@210.131.215.116
LAPLACE_LOCAL_PORT=8000
LAPLACE_REMOTE_PORT=8000

# --- Mode ---
# Set to 1 for dry-run (no real bets). Remove or set to 0 for live mode.
LAPLACE_FORCE_DRYRUN=1

# --- Verification Mode (fixed table for public broadcasting) ---
LAPLACE_MODE=verification
LAPLACE_FIXED_TABLE=Japanese Speed Baccarat A

# --- Notifications (optional, leave empty if not needed) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUBLIC_BOT_TOKEN=
PUBLIC_CHANNEL_ID=
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=
