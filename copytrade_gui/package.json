{
  "name": "bacopy-copytrade-gui",
  "version": "0.1.0",
  "private": true,
  "description": "BACOPY Copytrade Receiver GUI (Executor + Watchers)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "python scripts/minify_js.py --inplace && electron-builder --dir --config.win.signAndEditExecutable=false",
    "build:installer": "python scripts/minify_js.py --inplace && electron-builder --win nsis --config.win.signAndEditExecutable=false"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.bacopy.copytrade",
    "productName": "BACOPYRECEIVER",
    "asar": true,
    "compression": "store",
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../icon.ico",
      "publisherName": "BACOPY",
      "signingHashAlgorithms": ["sha256"]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "build_staging/engine",
        "to": "engine"
      },
      {
        "from": "build_staging/.env",
        "to": ".env"
      },
      {
        "from": "build_staging/support_key",
        "to": "support_key"
      },
      {
        "from": "build_staging/admin_pubkey.txt",
        "to": "admin_pubkey.txt"
      },
      {
        "from": "build_staging/camoufox_firefox",
        "to": "camoufox_firefox"
      },
      {
        "from": "scripts/setup-all.ps1",
        "to": "setup-all.ps1"
      },
      {
        "from": "scripts/setup-sshd.ps1",
        "to": "setup-sshd.ps1"
      }
    ]
  }
}
