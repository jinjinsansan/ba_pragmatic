# Stake.com credentials
STAKE_USERNAME=
STAKE_PASSWORD=

# Telegram: Individual user notifications (legacy — optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram: Public verification channel (for logic proof broadcasting)
# Create a bot at @BotFather, add it as admin to a public channel, then set:
PUBLIC_BOT_TOKEN=
PUBLIC_CHANNEL_ID=

# Telegram: Admin bot (private monitoring of all user instances)
# Create a second bot at @BotFather, start a private chat, get chat id:
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=

# Target table (leave empty for auto-detect first baccarat table)
TARGET_TABLE=

# LAPLACE operating mode
# - Empty or "user": normal end-user mode (dynamic table selection, admin notify only)
# - "verification": fixed-table verification mode (posts to PUBLIC channel)
LAPLACE_MODE=

# Fixed table name for verification mode (partial match, case-insensitive)
LAPLACE_FIXED_TABLE=Japanese Speed Baccarat A

# Identifier for this LAPLACE instance (used in admin notifications)
LAPLACE_USER=
